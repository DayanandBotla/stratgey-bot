# ╔══════════════════════════════════════════════════════════╗
# ║  AutoTrade Bot — Environment Variables                   ║
# ║  Copy this to .env and fill your real values            ║
# ║  NEVER commit .env to git                               ║
# ╚══════════════════════════════════════════════════════════╝

# ── Dhan API ──────────────────────────────────────────────
DHAN_CLIENT_ID=1108455416
DHAN_ACCESS_TOKEN=your_dhan_access_token_here

# ── Trading mode ──────────────────────────────────────────
# Set to "false" only after paper trade validation
PAPER_TRADE=true

# ── Capital & risk ────────────────────────────────────────
CAPITAL=500000
MAX_RISK_PCT=0.03
MAX_DAILY_TRADES=4
MAX_DAILY_LOSS=0.02

# ── Strategy filters ──────────────────────────────────────
MIN_CONFLUENCE=0.60
MIN_STRATEGY_AGREE=3
SCAN_INTERVAL_SEC=300

# ── Server ────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8001
# Your Hetzner VPS fixed IPv4 (needed for Dhan whitelist)
VPS_IP=YOUR_HETZNER_IP_HERE

# ── Instruments ───────────────────────────────────────────
# Comma-separated: NIFTY,BANKNIFTY or just NIFTY or BANKNIFTY
SCAN_INSTRUMENTS=NIFTY,BANKNIFTY
